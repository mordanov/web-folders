# --- Public domains used by the shared nginx/certbot layer ---
# First domain must be the primary one for the certificate.
RECIPES_PRIMARY_DOMAIN=recipes.example.com
RECIPES_SERVER_NAMES=recipes.example.com www.recipes.example.com

POETRY_PRIMARY_DOMAIN=poetry.example.com
POETRY_SERVER_NAMES=poetry.example.com www.poetry.example.com

MAINPAGE_PRIMARY_DOMAIN=mainpage.com
MAINPAGE_SERVER_NAMES=mainpage.com www.mainpage.com
MAINPAGE_404_DOMAIN=404.mainpage.com
MAINPAGE_TITLE="Mainpage"
# Optional: browser tab title. Empty means MAINPAGE_TITLE.
MAINPAGE_BROWSER_TITLE=
# Optional: domain used in button links. Empty means MAINPAGE_PRIMARY_DOMAIN.
MAINPAGE_LINK_DOMAIN=
# Toggle links: 1/true/yes/on = active, 0/false/no/off = disabled.
MAINPAGE_ENABLE_RECIPES=1
MAINPAGE_ENABLE_REMINDERS=1
MAINPAGE_ENABLE_FAMILYPHOTO=1
MAINPAGE_ENABLE_HOME=1
MAINPAGE_ENABLE_NEWS=1
MAINPAGE_ENABLE_BUDGET=1

# --- news-site ---
NEWS_PRIMARY_DOMAIN=news.mainpage.com
NEWS_SERVER_NAMES=news.mainpage.com

# Database
NEWS_POSTGRES_DB=news
NEWS_POSTGRES_USER=news_user
NEWS_POSTGRES_PASSWORD=change-me-news-db

# App security
NEWS_SECRET_KEY=change-me-news-secret

# Users (only 2 users supported)
NEWS_USER1_LOGIN=admin
NEWS_USER1_PASSWORD=change-me-password1
NEWS_USER2_LOGIN=user
NEWS_USER2_PASSWORD=change-me-password2

LETSENCRYPT_EMAIL=admin@example.com
CERTBOT_STAGING=0
CERTBOT_RENEW_INTERVAL_SECONDS=43200
NGINX_CERT_POLL_INTERVAL=300

# --- family-kitchen-recipes ---
RECIPES_POSTGRES_DB=recipes
RECIPES_POSTGRES_USER=recipes_user
RECIPES_POSTGRES_PASSWORD=change-me-recipes-db
RECIPES_SECRET_KEY=change-me-recipes-secret
RECIPES_OPENAI_API_KEY=
RECIPES_USER1_NAME=mama
RECIPES_USER1_PASSWORD=change-me-password1
RECIPES_USER2_NAME=papa
RECIPES_USER2_PASSWORD=change-me-password2
# Service account used by budget-site to call the receipt-parsing API
RECIPES_SERVICE_USER_NAME=kitchen_service
RECIPES_SERVICE_USER_PASSWORD=change-me-recipes-service-password

# --- poetry-site ---
POETRY_SECRET_KEY=change-me-poetry-secret
POETRY_ADMIN_USERNAME=admin
POETRY_ADMIN_PASSWORD=change-me-admin-password
POETRY_POET_NAME=Famous poet


# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_PATH=

# --- reminders-app ---
REMINDERS_PRIMARY_DOMAIN=reminders.mainpage.com
REMINDERS_SERVER_NAMES=reminders.mainpage.com

# Database
REMINDERS_POSTGRES_DB=reminders
REMINDERS_POSTGRES_USER=reminders_user
REMINDERS_POSTGRES_PASSWORD=change-me-reminders-db

# App security
REMINDERS_SECRET_KEY=change-me-reminders-secret

# Seed users (created on first start if absent)
REMINDERS_DEFAULT_USER1_USERNAME=user1
REMINDERS_DEFAULT_USER1_EMAIL=user1@family.local
REMINDERS_DEFAULT_USER1_PASSWORD=change-me-reminders-user1-password
REMINDERS_DEFAULT_USER2_USERNAME=user2
REMINDERS_DEFAULT_USER2_EMAIL=user2@family.local
REMINDERS_DEFAULT_USER2_PASSWORD=change-me-reminders-user2-password

# Email/SMTP (optional, leave blank to disable)
REMINDERS_SMTP_HOST=smtp.gmail.com
REMINDERS_SMTP_PORT=587
REMINDERS_SMTP_USER=
REMINDERS_SMTP_PASSWORD=
REMINDERS_SMTP_FROM=reminders@app.local

# Reminder check interval in seconds
REMINDERS_CHECK_INTERVAL=60

# --- budget-site ---
BUDGET_PRIMARY_DOMAIN=budget.mainpage.com
BUDGET_SERVER_NAMES=budget.mainpage.com

# Database
BUDGET_POSTGRES_DB=budget
BUDGET_POSTGRES_USER=budget_user
BUDGET_POSTGRES_PASSWORD=change-me-budget-db

# App security
BUDGET_SECRET_KEY=change-me-budget-secret
BUDGET_ALGORITHM=HS256
BUDGET_ACCESS_TOKEN_EXPIRE_MINUTES=60
BUDGET_ROBOT_API_TOKENS=

# App settings
BUDGET_ENVIRONMENT=production
BUDGET_MAX_UPLOAD_SIZE_MB=10
BUDGET_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf
BUDGET_ALLOWED_ORIGINS=https://budget.mainpage.com

# Seed users (created on first start if absent)
BUDGET_DEFAULT_USER1_NAME=User 1
BUDGET_DEFAULT_USER1_EMAIL=user1@family.local
BUDGET_DEFAULT_USER1_PASSWORD=change-me-budget-user1-password
BUDGET_DEFAULT_USER2_NAME=User 2
BUDGET_DEFAULT_USER2_EMAIL=user2@family.local
BUDGET_DEFAULT_USER2_PASSWORD=change-me-budget-user2-password

# Kitchen receipt integration (budget-site → family-kitchen-recipes)
# VITE_ vars are baked into the frontend JS bundle at build time.
# URL must be reachable from the user's browser (e.g. https://recipes.example.com/api).
BUDGET_KITCHEN_API_URL=https://recipes.example.com/api
BUDGET_KITCHEN_SERVICE_USER=kitchen_service
BUDGET_KITCHEN_SERVICE_PASSWORD=change-me-recipes-service-password

# --- family-admin-routine ---
ADMIN_ROUTINE_PRIMARY_DOMAIN=admin.mainpage.com
ADMIN_ROUTINE_SERVER_NAMES=admin.mainpage.com

# App security
ADMIN_ROUTINE_SECRET_KEY=change-me-admin-routine-secret

# Users (admin1 and admin2)
ADMIN_ROUTINE_USER1_USERNAME=admin1
ADMIN_ROUTINE_USER1_PASSWORD=change-me-admin1-password
ADMIN_ROUTINE_USER2_USERNAME=admin2
ADMIN_ROUTINE_USER2_PASSWORD=change-me-admin2-password
