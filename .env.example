# --- Public domains used by the shared nginx/certbot layer ---
# First domain must be the primary one for the certificate.
RECIPES_PRIMARY_DOMAIN=recipes.example.com
RECIPES_SERVER_NAMES=recipes.example.com www.recipes.example.com

POETRY_PRIMARY_DOMAIN=poetry.example.com
POETRY_SERVER_NAMES=poetry.example.com www.poetry.example.com

MAINPAGE_PRIMARY_DOMAIN=mainpage.com
MAINPAGE_SERVER_NAMES=mainpage.com www.mainpage.com
MAINPAGE_404_DOMAIN=404.mainpage.com
MAINPAGE_TITLE="Mainpage"
# Optional: browser tab title. Empty means MAINPAGE_TITLE.
MAINPAGE_BROWSER_TITLE=
# Optional: domain used in button links. Empty means MAINPAGE_PRIMARY_DOMAIN.
MAINPAGE_LINK_DOMAIN=
# Toggle links: 1/true/yes/on = active, 0/false/no/off = disabled.
MAINPAGE_ENABLE_RECIPES=1
MAINPAGE_ENABLE_REMINDERS=1
MAINPAGE_ENABLE_FAMILYPHOTO=1
MAINPAGE_ENABLE_HOME=1
MAINPAGE_ENABLE_NEWS=1
MAINPAGE_ENABLE_BUDGET=1
MAINPAGE_ENABLE_ADMIN=1
MAINPAGE_ENABLE_TIMELINE=1
MAINPAGE_ENABLE_HOMERESOURCES=1
MAINPAGE_ENABLE_EXPENSES=1
MAINPAGE_ENABLE_SERVINGA=1
MAINPAGE_ENABLE_TRAVELSEARCH=1

# --- news-site ---
NEWS_PRIMARY_DOMAIN=news.mainpage.com
NEWS_SERVER_NAMES=news.mainpage.com

# Database
NEWS_POSTGRES_DB=news
NEWS_POSTGRES_USER=news_user
NEWS_POSTGRES_PASSWORD=change-me-news-db

# App security
NEWS_SECRET_KEY=change-me-news-secret

# Users (only 2 users supported)
NEWS_USER1_LOGIN=admin
NEWS_USER1_PASSWORD=change-me-password1
NEWS_USER2_LOGIN=user
NEWS_USER2_PASSWORD=change-me-password2

LETSENCRYPT_EMAIL=admin@example.com
CERTBOT_STAGING=0
CERTBOT_RENEW_INTERVAL_SECONDS=43200
NGINX_CERT_POLL_INTERVAL=300

# --- family-kitchen-recipes ---
RECIPES_POSTGRES_DB=recipes
RECIPES_POSTGRES_USER=recipes_user
RECIPES_POSTGRES_PASSWORD=change-me-recipes-db
RECIPES_SECRET_KEY=change-me-recipes-secret
RECIPES_OPENAI_API_KEY=
RECIPES_USER1_NAME=mama
RECIPES_USER1_PASSWORD=change-me-password1
RECIPES_USER2_NAME=papa
RECIPES_USER2_PASSWORD=change-me-password2
# Service account used by budget-site to call the receipt-parsing API
RECIPES_SERVICE_USER_NAME=kitchen_service
RECIPES_SERVICE_USER_PASSWORD=change-me-recipes-service-password

# --- poetry-site ---
POETRY_SECRET_KEY=change-me-poetry-secret
POETRY_ADMIN_USERNAME=admin
POETRY_ADMIN_PASSWORD=change-me-admin-password
POETRY_POET_NAME=Famous poet


# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_PATH=

# --- reminders-app ---
REMINDERS_PRIMARY_DOMAIN=reminders.mainpage.com
REMINDERS_SERVER_NAMES=reminders.mainpage.com

# Database
REMINDERS_POSTGRES_DB=reminders
REMINDERS_POSTGRES_USER=reminders_user
REMINDERS_POSTGRES_PASSWORD=change-me-reminders-db

# App security
REMINDERS_SECRET_KEY=change-me-reminders-secret

# Seed users (created on first start if absent)
REMINDERS_DEFAULT_USER1_USERNAME=user1
REMINDERS_DEFAULT_USER1_EMAIL=user1@family.local
REMINDERS_DEFAULT_USER1_PASSWORD=change-me-reminders-user1-password
REMINDERS_DEFAULT_USER2_USERNAME=user2
REMINDERS_DEFAULT_USER2_EMAIL=user2@family.local
REMINDERS_DEFAULT_USER2_PASSWORD=change-me-reminders-user2-password

# Email/SMTP (optional, leave blank to disable)
REMINDERS_SMTP_HOST=smtp.gmail.com
REMINDERS_SMTP_PORT=587
REMINDERS_SMTP_USER=
REMINDERS_SMTP_PASSWORD=
REMINDERS_SMTP_FROM=reminders@app.local

# Reminder check interval in seconds
REMINDERS_CHECK_INTERVAL=60

# --- budget-site ---
BUDGET_PRIMARY_DOMAIN=budget.mainpage.com
BUDGET_SERVER_NAMES=budget.mainpage.com

# Database
BUDGET_POSTGRES_DB=budget
BUDGET_POSTGRES_USER=budget_user
BUDGET_POSTGRES_PASSWORD=change-me-budget-db

# App security
BUDGET_SECRET_KEY=change-me-budget-secret
BUDGET_ALGORITHM=HS256
BUDGET_ACCESS_TOKEN_EXPIRE_MINUTES=60
BUDGET_ROBOT_API_TOKENS=

# App settings
BUDGET_ENVIRONMENT=production
BUDGET_MAX_UPLOAD_SIZE_MB=10
BUDGET_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf
BUDGET_ALLOWED_ORIGINS=https://budget.mainpage.com

# Seed users (created on first start if absent)
BUDGET_DEFAULT_USER1_NAME=User 1
BUDGET_DEFAULT_USER1_EMAIL=user1@family.local
BUDGET_DEFAULT_USER1_PASSWORD=change-me-budget-user1-password
BUDGET_DEFAULT_USER2_NAME=User 2
BUDGET_DEFAULT_USER2_EMAIL=user2@family.local
BUDGET_DEFAULT_USER2_PASSWORD=change-me-budget-user2-password

# Kitchen receipt integration (budget-site → family-kitchen-recipes)
# VITE_ vars are baked into the frontend JS bundle at build time.
# URL must be reachable from the user's browser (e.g. https://recipes.example.com/api).
BUDGET_KITCHEN_API_URL=https://recipes.example.com/api
BUDGET_KITCHEN_SERVICE_USER=kitchen_service
BUDGET_KITCHEN_SERVICE_PASSWORD=change-me-recipes-service-password

# --- family-admin-routine ---
ADMIN_ROUTINE_PRIMARY_DOMAIN=admin.mainpage.com
ADMIN_ROUTINE_SERVER_NAMES=admin.mainpage.com

# App security
ADMIN_ROUTINE_SECRET_KEY=change-me-admin-routine-secret

# Users (admin1 and admin2)
ADMIN_ROUTINE_USER1_USERNAME=admin1
ADMIN_ROUTINE_USER1_PASSWORD=change-me-admin1-password
ADMIN_ROUTINE_USER2_USERNAME=admin2
ADMIN_ROUTINE_USER2_PASSWORD=change-me-admin2-password

# Backup storage backend.
#   s3    — push zip files to the Hetzner Object Storage that family-archive
#           already uses (credentials are inherited from ARCHIVE_S3_* above).
#   local — keep zip files on the admin_routine_backups_data docker volume.
ADMIN_ROUTINE_BACKUP_BACKEND=s3
# S3 prefix (folder) inside the bucket where backups are stored.
ADMIN_ROUTINE_BACKUP_S3_PREFIX=Backups/
# Optional overrides — leave blank to inherit ARCHIVE_S3_* values:
#ADMIN_ROUTINE_BACKUP_S3_ENDPOINT_URL=
#ADMIN_ROUTINE_BACKUP_S3_REGION=
#ADMIN_ROUTINE_BACKUP_S3_BUCKET=
#ADMIN_ROUTINE_BACKUP_S3_ACCESS_KEY=
#ADMIN_ROUTINE_BACKUP_S3_SECRET_KEY=
#ADMIN_ROUTINE_BACKUP_S3_FORCE_PATH_STYLE=

# GitHub Actions CI panel.
# Create a fine-grained PAT with Actions → Read-only scope for each repo.
# The list of repos is managed in ci-repos.yaml (mounted as a volume).
GITHUB_TOKEN=github_pat_xxxx
GITHUB_OWNER=your-github-username

# --- family-archive ---
ARCHIVE_PRIMARY_DOMAIN=archive.mainpage.com
ARCHIVE_SERVER_NAMES=archive.mainpage.com

# Database
ARCHIVE_POSTGRES_DB=archive
ARCHIVE_POSTGRES_USER=archive_user
ARCHIVE_POSTGRES_PASSWORD=change-me-archive-db

# App security
ARCHIVE_SECRET_KEY=change-me-archive-secret
ARCHIVE_COOKIE_DOMAIN=
ARCHIVE_SESSION_LIFETIME_DAYS=30

# Seed users (created on first start if absent). Only 2 users supported.
ARCHIVE_USER1_USERNAME=user1
ARCHIVE_USER1_PASSWORD=change-me-archive-user1
ARCHIVE_USER2_USERNAME=user2
ARCHIVE_USER2_PASSWORD=change-me-archive-user2

# Hetzner Object Storage (S3-compatible) — required, no defaults.
ARCHIVE_S3_ENDPOINT_URL=https://fsn1.your-objectstorage.com
ARCHIVE_S3_REGION=fsn1
ARCHIVE_S3_BUCKET=family-archive
ARCHIVE_S3_ACCESS_KEY=
ARCHIVE_S3_SECRET_KEY=
ARCHIVE_S3_FORCE_PATH_STYLE=1

# Limits
ARCHIVE_MAX_FILE_SIZE_BYTES=21474836480
ARCHIVE_CHUNK_SIZE_BYTES=8388608
ARCHIVE_TRASH_RETENTION_DAYS=30
ARCHIVE_THUMBNAIL_DIR=/app/data/thumbnails
ARCHIVE_PREWARM_THUMBNAIL_CONCURRENCY=4

# CORS (defaults to https://${ARCHIVE_PRIMARY_DOMAIN})
ARCHIVE_ALLOWED_ORIGINS=https://archive.mainpage.com

ARCHIVE_LOG_LEVEL=INFO

# --- portuguese-expenses ---
PORTUGUESE_EXPENSES_PRIMARY_DOMAIN=portugal2026.mainpage.com
PORTUGUESE_EXPENSES_SERVER_NAMES=portugal2026.mainpage.com

# Database
PORTUGUESE_EXPENSES_POSTGRES_DB=portuguese_expenses
PORTUGUESE_EXPENSES_POSTGRES_USER=portuguese_expenses_user
PORTUGUESE_EXPENSES_POSTGRES_PASSWORD=change-me-portuguese-expenses-db

# JWT (RS256) — generate with:
#   openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
#   awk 'NR==1{printf "%s",$0;next}{printf "\\n%s",$0}END{print ""}' private.pem
PORTUGUESE_EXPENSES_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
PORTUGUESE_EXPENSES_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"
PORTUGUESE_EXPENSES_JWT_ALGORITHM=RS256
PORTUGUESE_EXPENSES_JWT_EXPIRE_MINUTES=480

# App users (seeded by Alembic migration)
PORTUGUESE_EXPENSES_APP_USER_1_USERNAME=admin
PORTUGUESE_EXPENSES_APP_USER_1_PASSWORD=change-me-password1
PORTUGUESE_EXPENSES_APP_USER_2_USERNAME=editor
PORTUGUESE_EXPENSES_APP_USER_2_PASSWORD=change-me-password2

# OpenAI (gpt-4o vision for OCR)
PORTUGUESE_EXPENSES_OPENAI_API_KEY=sk-...

# File uploads
PORTUGUESE_EXPENSES_MAX_UPLOAD_SIZE_MB=10

# Frontend / CORS
PORTUGUESE_EXPENSES_FRONTEND_URL=https://portugal2026.mainpage.com
PORTUGUESE_EXPENSES_VITE_API_BASE_URL=https://portugal2026.mainpage.com/api

# --- home-resource-consumption ---
HOME_RESOURCES_PRIMARY_DOMAIN=home-resources.mainpage.com
HOME_RESOURCES_SERVER_NAMES=home-resources.mainpage.com

# Database
HOME_RESOURCES_POSTGRES_DB=home_resources
HOME_RESOURCES_POSTGRES_USER=home_resources_user
HOME_RESOURCES_POSTGRES_PASSWORD=change-me-home-resources-db

# Backend config
HOME_RESOURCES_OPENAI_API_KEY=sk-...replace-with-real-key...
HOME_RESOURCES_OPENAI_MODEL=gpt-4o-mini
HOME_RESOURCES_MAX_UPLOAD_SIZE_MB=10
HOME_RESOURCES_CORS_ORIGINS=https://home-resources.mainpage.com
HOME_RESOURCES_JWT_SECRET_KEY=replace-this-with-a-64-char-hex-string-generated-by-secrets-token-hex-32
HOME_RESOURCES_JWT_ALGORITHM=HS256
HOME_RESOURCES_ACCESS_TOKEN_EXPIRE_MINUTES=15
HOME_RESOURCES_REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional default user seed on first startup (leave blank to skip)
HOME_RESOURCES_DEFAULT_USER_USERNAME=admin
HOME_RESOURCES_DEFAULT_USER_EMAIL=admin@example.com
HOME_RESOURCES_DEFAULT_USER_PASSWORD=change-me-password

# --- google-timeline-web-app ---
GOOGLE_TIMELINE_PRIMARY_DOMAIN=timeline.mainpage.com
GOOGLE_TIMELINE_SERVER_NAMES=timeline.mainpage.com

# Database
GOOGLE_TIMELINE_POSTGRES_DB=google_timeline
GOOGLE_TIMELINE_POSTGRES_USER=google_timeline_user
GOOGLE_TIMELINE_POSTGRES_PASSWORD=change-me-google-timeline-db

# App security
GOOGLE_TIMELINE_JWT_SECRET=change-me-google-timeline-secret

# Seed user (created or password-synced on every start)
GOOGLE_TIMELINE_APP_USERNAME=admin
GOOGLE_TIMELINE_APP_PASSWORD=change-me-google-timeline-password

# CORS — comma-separated list of allowed origins
GOOGLE_TIMELINE_CORS_ORIGINS=https://timeline.mainpage.com

# Google Maps API key — baked into frontend JS bundle at build time
GOOGLE_TIMELINE_MAPS_API_KEY=your-google-maps-api-key

# Google Drive sync (importer)
# Paste the entire service account JSON as a single-line string
GOOGLE_TIMELINE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}'
GOOGLE_TIMELINE_DRIVE_FOLDER_ID=your-google-drive-folder-id
# Sync interval in seconds (default: 900 = 15 minutes)
GOOGLE_TIMELINE_SYNC_INTERVAL_SECONDS=900

# --- travelsearch ---
TRAVELSEARCH_PRIMARY_DOMAIN=travelsearch.mainpage.com
TRAVELSEARCH_SERVER_NAMES=travelsearch.mainpage.com

# Database
TRAVELSEARCH_POSTGRES_DB=travelsearch
TRAVELSEARCH_POSTGRES_USER=travelsearch_user
TRAVELSEARCH_POSTGRES_PASSWORD=change-me-travelsearch-db

# JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TRAVELSEARCH_JWT_SECRET=change-me-travelsearch-jwt-secret
TRAVELSEARCH_JWT_ALGORITHM=HS256
TRAVELSEARCH_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
TRAVELSEARCH_JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Telegram bot (for property change notifications)
TRAVELSEARCH_TELEGRAM_BOT_TOKEN=
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TRAVELSEARCH_TELEGRAM_WEBHOOK_SECRET=

# Scraping proxy pool (leave blank to scrape without proxy)
TRAVELSEARCH_PROXY_PROVIDER_HOST=
TRAVELSEARCH_PROXY_PROVIDER_USER=
TRAVELSEARCH_PROXY_PROVIDER_PASS=

# CORS — comma-separated list of allowed origins
TRAVELSEARCH_CORS_ORIGINS=https://travelsearch.mainpage.com

# Debug: set true only in dev to persist raw scraped JSONB (may contain PII)
TRAVELSEARCH_ENABLE_RAW_SNAPSHOT=false

# App environment
TRAVELSEARCH_APP_ENV=production

# pgview (pgweb — PostgreSQL web UI)
PGVIEW_PRIMARY_DOMAIN=pgview.admin.mainpage.com
PGVIEW_SERVER_NAMES=pgview.admin.mainpage.com
PGVIEW_USER=admin
PGVIEW_PASSWORD=change-me-pgview-password

# verdecora-bot (Telegram event notifier)
VERDECORA_TELEGRAM_TOKEN=        # required — Telegram bot token from @BotFather
VERDECORA_CHAT_ID=               # required — Telegram chat/group ID to send notifications to
VERDECORA_CHECK_INTERVAL=300     # optional — polling interval in seconds (default: 300)

