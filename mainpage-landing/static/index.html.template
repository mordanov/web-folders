<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>__MAINPAGE_BROWSER_TITLE__</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f5f7fb;
      --card: #ffffff;
      --text: #1f2937;
      --muted: #4b5563;
      --ring: #dbe3f3;
      --ring-hover: #c3d4f7;
      --shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Inter, Helvetica, Arial, sans-serif;
      background: radial-gradient(circle at top, #ffffff 0%, var(--bg) 55%);
      color: var(--text);
      padding: 24px;
    }

    .container {
      width: min(760px, 100%);
      text-align: center;
    }

    h1 {
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      margin: 0 0 24px;
      font-weight: 700;
      letter-spacing: 0.01em;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }

    .tile {
      text-decoration: none;
      color: inherit;
      background: var(--card);
      border: 1px solid var(--ring);
      border-radius: 16px;
      min-height: 150px;
      padding: 18px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
      box-shadow: var(--shadow);
    }

    .tile:hover,
    .tile:focus-visible {
      transform: translateY(-2px);
      border-color: var(--ring-hover);
      box-shadow: 0 14px 28px rgba(59, 130, 246, 0.18);
      outline: none;
    }

    .tile img {
      width: 58px;
      height: 58px;
    }

    .tile span {
      font-size: 1rem;
      font-weight: 600;
      color: var(--muted);
    }

    .tile.disabled {
      cursor: not-allowed;
      opacity: 0.92;
    }

    .tile.disabled:hover,
    .tile.disabled:focus-visible {
      transform: none;
      border-color: var(--ring);
      box-shadow: var(--shadow);
      outline: none;
    }

    .tile.disabled img {
      filter: grayscale(1);
      opacity: 0.72;
    }

    .tile.disabled span {
      color: #6b7280;
    }

    @media (max-width: 640px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <main class="container">
    <h1>__MAINPAGE_TITLE__</h1>
    <div class="grid">
      <a class="tile __RECIPES_LINK_CLASS__" href="__RECIPES_LINK_HREF__" title="__RECIPES_LINK_TITLE__" aria-disabled="__RECIPES_LINK_ARIA_DISABLED__" tabindex="__RECIPES_LINK_TABINDEX__">
        <img src="/icons/recipes.svg" alt="">
        <span>&#1056;&#1077;&#1094;&#1077;&#1087;&#1090;&#1099; &#1085;&#1072;&#1096;&#1077;&#1081; &#1089;&#1077;&#1084;&#1100;&#1080;</span>
      </a>
      <a class="tile __REMINDERS_LINK_CLASS__" href="__REMINDERS_LINK_HREF__" title="__REMINDERS_LINK_TITLE__" aria-disabled="__REMINDERS_LINK_ARIA_DISABLED__" tabindex="__REMINDERS_LINK_TABINDEX__">
        <img src="/icons/reminders.svg" alt="">
        <span>&#1053;&#1072;&#1087;&#1086;&#1084;&#1080;&#1085;&#1072;&#1085;&#1080;&#1103;</span>
      </a>
      <a class="tile __FAMILYPHOTO_LINK_CLASS__" href="__FAMILYPHOTO_LINK_HREF__" title="__FAMILYPHOTO_LINK_TITLE__" aria-disabled="__FAMILYPHOTO_LINK_ARIA_DISABLED__" tabindex="__FAMILYPHOTO_LINK_TABINDEX__">
        <img src="/icons/archive.svg" alt="">
        <span>&#1057;&#1077;&#1084;&#1077;&#1081;&#1085;&#1099;&#1081; &#1072;&#1088;&#1093;&#1080;&#1074;</span>
      </a>
      <a class="tile __HOME_LINK_CLASS__" href="__HOME_LINK_HREF__" title="__HOME_LINK_TITLE__" aria-disabled="__HOME_LINK_ARIA_DISABLED__" tabindex="__HOME_LINK_TABINDEX__">
        <img src="/icons/home.svg" alt="">
        <span>&#1059;&#1084;&#1085;&#1099;&#1081; &#1076;&#1086;&#1084;</span>
      </a>
    </div>
  </main>
</body>
</html>

